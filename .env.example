# Application Settings
APP_NAME="Gamified Life-Agent Engine"
SECRET_KEY="your-secret-key-here"
DEBUG=true

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=gamified_life

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM (LiteLLM)
DEFAULT_MODEL=gpt-4
FALLBACK_MODELS=gpt-3.5-turbo,claude-3-opus
LITELLM_API_KEY=your-api-key-here
LITELLM_BASE_URL=

# MCP Server
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# Flask
HOST=0.0.0.0
PORT=5000

# Game Mechanics
BASE_XP_PER_TASK=100
DROP_RATE_BASE=0.1
